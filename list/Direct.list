# Direct / Domain 仅承担补充层：
# 只保留 China / Domain 未覆盖、但仍需直连的少量国内补丁。

# 基础服务 / 更新 / 静态资源
DOMAIN-SUFFIX,time.windows.com
DOMAIN-SUFFIX,qhupdate.com
DOMAIN-SUFFIX,aliapp.org
DOMAIN-SUFFIX,mmstat.com
DOMAIN-SUFFIX,baidustatic.com
DOMAIN-SUFFIX,snssdk.com
DOMAIN-SUFFIX,toutiaopage.com
DOMAIN-SUFFIX,71.am
DOMAIN-SUFFIX,meitustat.com
DOMAIN-SUFFIX,sohuno.com
DOMAIN-SUFFIX,tencentmind.com

# 国内前端静态资源 / 公共分发
DOMAIN-SUFFIX,bootcss.com
DOMAIN-SUFFIX,staticfile.org
DOMAIN-SUFFIX,fengkongcloud.com
DOMAIN-SUFFIX,jiathis.com
DOMAIN-SUFFIX,lancdns.com

# 国内站点补丁
DOMAIN-SUFFIX,biquge.com
DOMAIN-SUFFIX,cn163.net
DOMAIN-SUFFIX,easou.com
DOMAIN-SUFFIX,koowo.com
DOMAIN-SUFFIX,tmiaoo.com

#指令使用了关键字直连，只要网址带有 m-team 即会直连，推荐使用
- DOMAIN-KEYWORD,m-team,DIRECT

#指令使用了主域名直連，不論子域名為何皆為直連，有兩條紀錄是因為擁有兩個入口網址
- DOMAIN-SUFFIX,m-team.cc,DIRECT
- DOMAIN-SUFFIX,m-team.io,DIRECT
- DOMAIN-SUFFIX,manfuz.co,DIRECT

#指令使用了指定域名直連，只要網址是指定的域名才會直連，不推薦使用(因为域名可能会不定期更新)
- DOMAIN,tracker.m-team.cc,DIRECT
- DOMAIN,tracker.m-team.io,DIRECT
- DOMAIN,tra1.m-team.cc,DIRECT
- DOMAIN,tra1.m-team.io,DIRECT
- DOMAIN,tra99.manfuz.co,DIRECT

#局域网
- IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
- IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
- IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
- IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
